# Jellyfin Face Swap — Configuration
# Copy this file to .env and fill in your values

# Required — Jellyfin server
JELLYFIN_URL=http://your-jellyfin-server:8096
JELLYFIN_API_KEY=your_jellyfin_api_key

# Required — Google Gemini (powers both face analysis and image generation)
GEMINI_API_KEY=your_google_ai_api_key

# Backdrop upload method (default: api)
# api   = Upload via Jellyfin API (recommended, works everywhere)
# ssh   = Write files directly via SSH (advanced)
# local = Write files directly on local filesystem
# BACKDROP_UPLOAD=api

# Only needed for BACKDROP_UPLOAD=ssh
# MEDIA_SSH=user@jellyfin-host

# Only needed for ssh/local when Jellyfin runs in Docker
# Maps Jellyfin container paths to host filesystem paths
# JF_PATH_PREFIX=/media/
# HOST_PATH_PREFIX=/mnt/media/

# Optional — Alternative AI backends
# ANTHROPIC_API_KEY=sk-ant-your-key    # For Claude Vision analysis
# FAL_KEY=your-fal-ai-key              # For fal.ai face swap
# ANALYSIS_BACKEND=gemini              # gemini or claude
# SWAP_BACKEND=gemini                  # gemini or fal

# Server settings
# HOST=0.0.0.0
# PORT=8000
