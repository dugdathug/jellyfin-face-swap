# Jellyfin Face Swap — Configuration
# Copy this file to .env and fill in your values

# Required — Jellyfin server
JELLYFIN_URL=http://your-jellyfin-server:8096
JELLYFIN_API_KEY=your_jellyfin_api_key

# Required — Google Gemini (powers both face analysis and image generation)
GEMINI_API_KEY=your_google_ai_api_key

# Optional — Alternative AI backends
# ANTHROPIC_API_KEY=sk-ant-your-key    # For Claude Vision analysis
# FAL_KEY=your-fal-ai-key              # For fal.ai face swap
# ANALYSIS_BACKEND=gemini              # gemini or claude
# SWAP_BACKEND=gemini                  # gemini or fal

# Optional — Authentication (if not set, no auth required)
# AUTH_TOKEN=your_secret_token_here

# Server settings
# HOST=0.0.0.0
# PORT=8000
